{
  "entities": {
    "Material": {
      "title": "Material",
      "description": "Inventory material configuration",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Metal", "Plastic", "Paper", "Glass", "Electronics", "Other"] },
        "unit": { "type": "string" },
        "buyPrice": { "type": "number" },
        "sellPrice": { "type": "number" },
        "currentStock": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "name", "type", "unit", "buyPrice", "sellPrice", "currentStock", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A buy or sell transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "materialId": { "type": "string" },
        "quantity": { "type": "number" },
        "pricePerUnit": { "type": "number" },
        "discount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "totalAmount": { "type": "number" },
        "clientName": { "type": "string" },
        "notes": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "type", "materialId", "quantity", "pricePerUnit", "totalAmount", "clientName", "date", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An operational expense record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "amount", "category", "description", "date", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "Client CRM entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "name", "type", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}/clients/{clientId}": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "CRM Clients per user"
    },
    "users/{userId}/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Expenses per user"
    },
    "users/{userId}/materials/{materialId}": {
      "schema": { "$ref": "#/entities/Material" },
      "description": "Materials per user"
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Transactions per user"
    }
  }
}
